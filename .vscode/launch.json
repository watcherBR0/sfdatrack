            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Python train",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--script=UMDATrack",
                "--config=baseline_vit",
                "--save_dir=./output",
            ]
        },
        {
            "name": "Python test",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "UMDATrack",
                "baseline_256",
                "--dataset_name=dtb70_dark",
                "--num_gpus=1",
